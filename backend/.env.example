GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here   # free tier: tavily.com
DATABASE_URL=sqlite+aiosqlite:///./sdr.db

# Set to true to test send/inbox without Gmail credentials
DRY_RUN=true

# Fallback sender if prospect has no campaign attached
SENDER_EMAIL=you@gmail.com

# Gmail OAuth (Week 3) — run auth_gmail.py to generate token.json
GMAIL_TOKEN_PATH=token.json
