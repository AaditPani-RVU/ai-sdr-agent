GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here   # free tier: tavily.com
DATABASE_URL=sqlite+aiosqlite:///./sdr.db

# Set to true to test send/inbox without Gmail credentials
DRY_RUN=true

# Fallback sender if prospect has no campaign attached
SENDER_EMAIL=you@gmail.com

# Gmail OAuth (Week 3) — run auth_gmail.py to generate token.json
GMAIL_TOKEN_PATH=token.json

# Optional: Slack incoming webhook URL for "booked" prospect notifications
# Create one at api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Google Calendar ID to poll for booked meetings (default: primary)
GOOGLE_CALENDAR_ID=primary

# Your Google Calendar appointment scheduling link — included in outreach emails
# Create free at: calendar.google.com → click your calendar → "Set up a booking page"
BOOKING_LINK=https://calendar.app.google/s5TVtFbHMxMHDVFy5
